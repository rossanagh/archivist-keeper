{
  "appId": "com.inventoryapp.app",
  "productName": "InventoryApp",
  "directories": {
    "output": "dist-electron",
    "buildResources": "public"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "public/pwa-512x512.png",
    "artifactName": "${productName}-${version}-${arch}.${ext}"
  },
  "portable": {
    "artifactName": "InventoryApp-Portable-${version}.exe"
  },
  "extraMetadata": {
    "main": "electron/main.cjs"
  }
}
